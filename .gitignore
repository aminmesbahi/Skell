#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov
cov
$cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

dist/
skell.exe
skell

# Editor/IDE
# .idea/
# .vscode/

# ---- Wails GUI ----

# Frontend dependencies
gui/frontend/node_modules/

# Frontend build output
gui/frontend/dist/

# Vite cache
gui/frontend/.vite/

# Vitest coverage output
gui/frontend/coverage/

# Playwright
gui/frontend/playwright-report/
gui/frontend/test-results/
gui/frontend/.playwright/

# Wails build outputs
gui/build/bin/
gui/frontend/wailsjs/

# Bun
# bun.lock is intentionally committed (lockfile)

# Wails dev temp files
gui/frontend/package.json.md5
